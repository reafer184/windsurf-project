{
  "appId": "ru.totp.authenticator",
  "appName": "TOTP Authenticator",
  "webDir": ".",
  "bundledWebRuntime": false,
  "server": {
    "androidScheme": "https",
    "cleartext": false
  },
  "plugins": {
    "Camera": {
      "permissions": ["camera"]
    },
    "Preferences": {}
  },
  "ios": {
    "contentInset": "automatic",
    "allowsLinkPreview": false,
    "scrollEnabled": true,
    "webviewSuspendingDelay": 0
  }
}
